<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="sub_REPORT_NAME" pageWidth="515" pageHeight="802" columnWidth="515"
              leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">

    <!-- Un <field> por cada getter del bean fuente. JRBeanCollectionDataSource
         resuelve $F{xxx} por convención de JavaBean: field "unitPrice" ->
         getUnitPrice(). Sin el getter, el campo queda vacío sin error. -->
    <field name="EXAMPLE_FIELD" class="java.lang.String"/>

    <columnHeader>
        <band height="20">
            <staticText>
                <reportElement x="0" y="0" width="200" height="20"/>
                <textElement verticalAlignment="Middle"/>
                <text><![CDATA[Columna]]></text>
            </staticText>
            <line>
                <reportElement x="0" y="19" width="515" height="1"/>
            </line>
        </band>
    </columnHeader>

    <detail>
        <band height="16">
            <textField isStretchWithOverflow="true">
                <reportElement x="0" y="0" width="200" height="16"/>
                <textElement verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{EXAMPLE_FIELD}]]></textFieldExpression>
            </textField>
        </band>
    </detail>
</jasperReport>
